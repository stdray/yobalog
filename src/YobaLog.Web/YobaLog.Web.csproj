<Project Sdk="Microsoft.NET.Sdk.Web">

	<PropertyGroup>
		<!-- Protobuf-generated code (Trace.cs / Logs.cs / Common.cs under obj/) sprinkles
		     nullable-ref-type annotations (`?`) without a `#nullable enable` directive, which
		     Roslyn on Linux surfaces as CS8632 (Windows toolchain quietly treats these as
		     generated code and suppresses). `// <auto-generated>` pragma in the file doesn't
		     cover CS8632 — it's a raw compiler warning, not an analyzer one. No user code in
		     this project uses nullable-ref annotations outside a nullable-enable context
		     (Directory.Build.props sets <Nullable>enable</Nullable> globally), so the only
		     source of this warning is the generated .pb.cs files. Global suppress is safe. -->
		<NoWarn>$(NoWarn);CS8632</NoWarn>
	</PropertyGroup>

	<ItemGroup>
		<ProjectReference Include="..\YobaLog.Core\YobaLog.Core.csproj" />
	</ItemGroup>

	<!-- OTLP Logs proto types (Phase F). Referenced here, not in Core. Decision-log 2026-04-21
	     Rule 1: proto DTOs are wire-boundary only (mirror of CLEF's JsonElement exception) and
	     must not leak into ILogStore / ISpanStore contracts. Keeping Google.Protobuf + Grpc.Tools
	     out of Core enforces that at the project-reference level.
	     `OpenTelemetry.Proto` NuGet does not exist (confirmed 2026-04-21) — Proto/ contains the
	     four vendored .proto files from opentelemetry-proto v1.5.0; Grpc.Tools compiles them to
	     C# classes during MSBuild. GrpcServices=None skips service/stub generation — we only
	     need message types. -->
	<ItemGroup>
		<PackageReference Include="Google.Protobuf" />
		<PackageReference Include="Grpc.Tools" PrivateAssets="all" />
	</ItemGroup>

	<ItemGroup>
		<Protobuf Include="Proto\**\*.proto" ProtoRoot="Proto" GrpcServices="None" />
	</ItemGroup>

	<!-- OpenTelemetry self-emission (Phase G). Gated on !IsEnvironment("Testing") in
	     YobaLogApp so unit + E2E suites don't pay the ActivityListener tax — tests that
	     need to assert emission opt in via local ActivityListener in the fixture. -->
	<ItemGroup>
		<PackageReference Include="OpenTelemetry" />
		<PackageReference Include="OpenTelemetry.Extensions.Hosting" />
		<PackageReference Include="OpenTelemetry.Instrumentation.AspNetCore" />
		<PackageReference Include="OpenTelemetry.Instrumentation.Http" />
	</ItemGroup>

	<!-- Frontend is Release-only from MSBuild. Debug relies on the Cake `Dev` target (or
	     a manual `bun run dev`) so dotnet watch doesn't fight the bun watcher for wwwroot/
	     output, and Rider's long-lived Web process doesn't block the bun-build output-copy step. -->
	<Target Name="BuildFrontend" BeforeTargets="Build" Condition="'$(Configuration)' == 'Release'">
		<Exec Command="bun install --frozen-lockfile" WorkingDirectory="$(MSBuildProjectDirectory)" />
		<Exec Command="bun run build" WorkingDirectory="$(MSBuildProjectDirectory)" />
	</Target>

</Project>
