<!DOCTYPE html>
<html lang="en" data-theme="dark" class="h-full">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewData["Title"] - YobaLog</title>
	<link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
	<script src="~/js/htmx.min.js" asp-append-version="true"></script>
	<script src="~/js/htmx-ext-sse.js" asp-append-version="true"></script>
	<script type="module" src="~/js/admin.js" asp-append-version="true"></script>
</head>
<body class="min-h-full">
	<div class="navbar bg-base-200 border-b border-base-300">
		<div class="mx-auto max-w-6xl w-full px-4 flex gap-6 items-center">
			<a class="text-lg font-semibold" asp-page="/Index">YobaLog</a>
			<a class="text-sm opacity-70 hover:opacity-100" asp-page="/Index">Workspaces</a>
			@if (User.Identity?.IsAuthenticated == true)
			{
				<a class="text-sm opacity-70 hover:opacity-100" asp-page="/Admin/Workspaces">Admin</a>
				<a class="text-sm opacity-70 hover:opacity-100" asp-page="/Admin/AgentKey">Agent</a>
			}
			@if (User.Identity?.IsAuthenticated == true)
			{
				<form method="post" action="/Logout" class="ml-auto flex items-center gap-3">
					<a asp-page="/Admin/Profile" data-testid="profile-link" class="text-sm opacity-70 hover:opacity-100">@User.Identity.Name</a>
					<button type="submit" data-testid="logout-submit" class="btn btn-xs btn-ghost">Sign out</button>
				</form>
			}
		</div>
	</div>
	<main class="mx-auto max-w-6xl px-4 py-6">
		@RenderBody()
	</main>
	@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
