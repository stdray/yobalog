@page "/ws/{id}/traces"
@model YobaLog.Web.Pages.TracesModel
@{
	ViewData["Title"] = $"Traces — {Model.Workspace.Value}";
}

<nav class="mb-4 flex flex-wrap items-center gap-2 text-sm" aria-label="breadcrumb">
	<a asp-page="/Workspace" asp-route-id="@Model.Workspace.Value"
		class="hover:opacity-100 opacity-60" data-testid="traces-back-workspace">@Model.Workspace.Value</a>
	<span class="opacity-40">/</span>
	<span class="font-mono font-semibold text-base">traces</span>
	<span class="badge badge-ghost text-xs ml-2" data-testid="traces-count">@Model.Traces.Length traces</span>
</nav>

<form method="get" asp-page="/Traces" asp-route-id="@Model.Workspace.Value" class="mb-4">
	<label class="form-control w-full">
		<span class="label-text mb-1 text-xs opacity-70">KQL filter — span-level, a trace shows if any of its spans match</span>
		<div class="flex gap-2">
			<textarea name="kql" rows="2" data-testid="traces-kql"
				placeholder="spans | where Name contains 'error' and Duration > 100000000"
				class="textarea textarea-bordered font-mono text-xs flex-1">@Model.Kql</textarea>
			<button type="submit" class="btn btn-sm btn-primary self-end" data-testid="traces-apply">Apply</button>
		</div>
	</label>
</form>

@if (Model.KqlError is not null)
{
	<div class="alert alert-error mb-3 py-2 text-sm" data-testid="traces-kql-error">@Model.KqlError</div>
}

@if (Model.Traces.IsEmpty)
{
	<div class="alert alert-info" data-testid="traces-empty">
		@if (!string.IsNullOrWhiteSpace(Model.Kql))
		{
			<span>No traces match the filter.</span>
		}
		else
		{
			<span>No traces yet in <code class="font-mono">@Model.Workspace.Value</code>.</span>
		}
	</div>
}
else
{
	<div class="bg-base-200 border border-base-300 overflow-hidden rounded-box" data-testid="traces-list">
		<table class="table table-sm w-full">
			<thead>
				<tr class="bg-base-300 text-xs">
					<th>Trace ID</th>
					<th>Root span</th>
					<th>Started</th>
					<th class="text-right">Duration</th>
					<th class="text-right">Spans</th>
					<th>Status</th>
				</tr>
			</thead>
			@{
				// Incremental auto-refresh: every 5s, htmx GETs the same page with `since` set
				// via JS to the topmost row's StartUnixNs. Server returns only newer traces
				// (SinceStartUnixNs branch in TracesModel) as a _TracesRows partial;
				// hx-swap="afterbegin" prepends them. No full-page reload, existing rows stay
				// put — scroll position preserved, expanded waterfalls (future feature)
				// wouldn't collapse.
				//
				// hx-vals js:{…} is evaluated on every request so `since` always reflects the
				// current DOM state. When there's a KQL filter active, it's passed along too
				// (otherwise the poll would ignore the filter and prepend unrelated traces).
			}
			<tbody id="traces-body"
				hx-get="/ws/@Model.Workspace.Value/traces"
				hx-trigger="every 5s"
				hx-vals='js:{since: (document.querySelector("#traces-body tr[data-start-unix-ns]")?.dataset.startUnixNs ?? "0"), kql: document.querySelector("[data-testid=traces-kql]")?.value ?? ""}'
				hx-swap="afterbegin">
				<partial name="_TracesRows" model="@Model.Traces" />
			</tbody>
		</table>
	</div>

	@if (Model.NextCursor is not null)
	{
		<div class="mt-4 text-center">
			<a asp-page="/Traces" asp-route-id="@Model.Workspace.Value"
				asp-route-cursor="@Model.NextCursor" asp-route-kql="@Model.Kql"
				class="btn btn-ghost btn-sm" data-testid="traces-next">Older →</a>
		</div>
	}
}
