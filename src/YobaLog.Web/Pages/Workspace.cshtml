@page "/ws/{id}"
@model YobaLog.Web.Pages.WorkspaceModel
@{
	ViewData["Title"] = Model.Workspace.Value;

	string LevelBadge(YobaLog.Core.LogLevel l) => l switch
	{
		YobaLog.Core.LogLevel.Verbose => "badge-ghost",
		YobaLog.Core.LogLevel.Debug => "badge-ghost",
		YobaLog.Core.LogLevel.Information => "badge-info",
		YobaLog.Core.LogLevel.Warning => "badge-warning",
		YobaLog.Core.LogLevel.Error => "badge-error",
		YobaLog.Core.LogLevel.Fatal => "badge-error",
		_ => "badge-ghost",
	};
}

<div class="mb-4 flex items-baseline gap-3">
	<a asp-page="/Index" class="text-sm opacity-60 hover:opacity-100">← workspaces</a>
	<h1 class="text-2xl font-semibold font-mono @(Model.Workspace.IsSystem ? "text-secondary" : "")">@Model.Workspace.Value</h1>
</div>

<form method="get" class="mb-4 bg-base-200 border border-base-300 rounded-box p-4 grid grid-cols-1 md:grid-cols-6 gap-3">
	<label class="form-control md:col-span-2">
		<span class="label-text text-xs opacity-70">Message contains</span>
		<input type="text" name="message" value="@Model.Message" class="input input-sm input-bordered" />
	</label>
	<label class="form-control">
		<span class="label-text text-xs opacity-70">Min level</span>
		<select name="minLevel" class="select select-sm select-bordered">
			<option value="">(any)</option>
			@foreach (var lvl in Enum.GetValues<YobaLog.Core.LogLevel>())
			{
				<option value="@lvl" selected="@(Model.MinLevel == lvl)">@lvl</option>
			}
		</select>
	</label>
	<label class="form-control">
		<span class="label-text text-xs opacity-70">Trace ID</span>
		<input type="text" name="traceId" value="@Model.TraceId" class="input input-sm input-bordered font-mono" />
	</label>
	<label class="form-control">
		<span class="label-text text-xs opacity-70">From (UTC)</span>
		<input type="datetime-local" name="from" value="@Model.From" class="input input-sm input-bordered" />
	</label>
	<label class="form-control">
		<span class="label-text text-xs opacity-70">To (UTC)</span>
		<input type="datetime-local" name="to" value="@Model.To" class="input input-sm input-bordered" />
	</label>
	<div class="md:col-span-6 flex gap-2">
		<button type="submit" class="btn btn-sm btn-primary">Apply</button>
		<a asp-page="/Workspace" asp-route-id="@Model.Workspace.Value" class="btn btn-sm btn-ghost">Reset</a>
	</div>
</form>

@if (Model.SchemaMissing)
{
	<div class="alert">Workspace has no events yet.</div>
}
else if (Model.Events.Count == 0)
{
	<div class="alert">No events match the filter.</div>
}
else
{
	<div class="overflow-x-auto rounded-box border border-base-300 bg-base-200">
		<table class="table table-sm">
			<thead>
				<tr>
					<th class="w-44">Time (UTC)</th>
					<th class="w-24">Level</th>
					<th>Message</th>
					<th class="w-40">Trace</th>
				</tr>
			</thead>
			<tbody>
				@foreach (var e in Model.Events)
				{
					<tr class="align-top hover">
						<td class="font-mono text-xs opacity-70 whitespace-nowrap">@e.Timestamp.ToString("yyyy-MM-dd HH:mm:ss.fff")</td>
						<td><span class="badge badge-sm @LevelBadge(e.Level)">@e.Level</span></td>
						<td class="break-words">
							<div>@e.Message</div>
							@if (!string.IsNullOrEmpty(e.Exception))
							{
								<pre class="mt-1 text-xs text-error whitespace-pre-wrap">@e.Exception</pre>
							}
						</td>
						<td class="font-mono text-xs opacity-70 truncate">@e.TraceId</td>
					</tr>
				}
			</tbody>
		</table>
	</div>

	@if (Model.NextCursor is not null)
	{
		<div class="mt-3">
			<a asp-page="/Workspace"
				asp-route-id="@Model.Workspace.Value"
				asp-route-from="@Model.From"
				asp-route-to="@Model.To"
				asp-route-minLevel="@Model.MinLevel"
				asp-route-traceId="@Model.TraceId"
				asp-route-message="@Model.Message"
				asp-route-cursor="@Model.NextCursor"
				class="btn btn-sm btn-ghost">
				Load older →
			</a>
		</div>
	}
}
