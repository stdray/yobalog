@page "/ws/{id}"
@model YobaLog.Web.Pages.WorkspaceModel
@{
	ViewData["Title"] = Model.Workspace.Value;
}

<div class="mb-4 flex items-baseline gap-3 flex-wrap">
	<a asp-page="/Index" class="text-sm opacity-60 hover:opacity-100">← workspaces</a>
	<h1 class="text-2xl font-semibold font-mono @(Model.Workspace.IsSystem ? "text-secondary" : "")">@Model.Workspace.Value</h1>
	@if (Model.ActiveSavedName is not null)
	{
		<span class="badge badge-primary font-mono">saved: @Model.ActiveSavedName</span>
	}
</div>

@if (Model.SavedQueries.Count > 0)
{
	<div class="mb-4 flex flex-wrap items-center gap-2 text-xs">
		<span class="opacity-60">Saved:</span>
		@foreach (var sq in Model.SavedQueries)
		{
			<span class="join">
				<a asp-page="/Workspace"
					asp-route-id="@Model.Workspace.Value"
					asp-route-saved="@sq.Name"
					class="btn btn-xs join-item font-mono @(Model.ActiveSavedName == sq.Name ? "btn-primary" : "btn-ghost")">@sq.Name</a>
				<form method="post" asp-page-handler="delete" asp-route-id="@Model.Workspace.Value" class="join-item">
					<input type="hidden" name="savedId" value="@sq.Id" />
					<button type="submit" class="btn btn-xs btn-ghost"
						onclick="return confirm('Delete saved query @sq.Name?');"
						title="Delete">×</button>
				</form>
			</span>
		}
	</div>
}

<form method="get" class="mb-4 bg-base-200 border border-base-300 rounded-box p-4 flex flex-col gap-3">
	<div class="relative" id="kql-editor">
		<textarea name="kql" rows="6" id="kql-textarea"
			placeholder="events | where Level >= 3 | where Message contains 'boom'"
			hx-get="/api/kql/completions"
			hx-trigger="keyup changed delay:250ms, click"
			hx-target="#kql-completions"
			hx-swap="innerHTML"
			hx-vals='js:{ q: document.getElementById("kql-textarea").value, pos: document.getElementById("kql-textarea").selectionStart }'
			class="textarea textarea-sm textarea-bordered w-full font-mono text-xs">@Model.UserKql</textarea>
		<div id="kql-completions" class="absolute left-0 right-0 top-full z-10"></div>
	</div>
	<p class="text-xs opacity-60 -mt-2">Paging (<code>order by</code>, <code>take</code>, cursor) appended automatically.</p>

	<div class="flex gap-2 flex-wrap items-center">
		<button type="submit" class="btn btn-sm btn-primary">Apply</button>
		<a asp-page="/Workspace" asp-route-id="@Model.Workspace.Value" class="btn btn-sm btn-ghost">Reset</a>
		@if (!Model.IsShapeChanged)
		{
			<label class="label cursor-pointer gap-2 ml-auto">
				<span class="label-text text-xs">Live tail</span>
				<input type="checkbox" id="live-tail-toggle" class="toggle toggle-sm toggle-primary"
					data-workspace="@Model.Workspace.Value"
					data-kql="@Model.UserKql" />
			</label>
		}
	</div>
</form>

<form method="post" asp-page-handler="save" asp-route-id="@Model.Workspace.Value"
	class="mb-4 flex gap-2 items-end flex-wrap">
	<label class="form-control flex-1 min-w-48">
		<span class="label-text text-xs opacity-70">Save current query as</span>
		<input type="text" name="name" value="@Model.ActiveSavedName" required
			placeholder="errors-last-hour"
			pattern="[A-Za-z0-9 _\-]+"
			class="input input-sm input-bordered" />
	</label>
	<input type="hidden" name="kql" value="@Model.UserKql" />
	<button type="submit" class="btn btn-sm btn-secondary">Save as…</button>
	@if (!Model.IsShapeChanged)
	{
		<button type="button" class="btn btn-sm btn-accent"
			data-share-modal-open
			data-workspace="@Model.Workspace.Value"
			data-kql="@Model.UserKql">Share as TSV…</button>
	}
</form>

<dialog id="share-modal" class="modal">
	<div class="modal-box max-w-2xl">
		<h3 class="text-lg font-semibold mb-1">Share as TSV</h3>
		<p class="text-xs opacity-70 mb-3">Anonymous URL returning TSV. Pick which fields get masked (HMAC — connections stay, values don't leak) or hidden.</p>

		<div class="mb-3 flex items-center gap-2">
			<span class="text-xs opacity-70">Expires in:</span>
			<div class="join" data-share-ttl-group>
				<button type="button" class="btn btn-xs join-item" data-ttl="1">1h</button>
				<button type="button" class="btn btn-xs join-item btn-active" data-ttl="24">24h</button>
				<button type="button" class="btn btn-xs join-item" data-ttl="168">7d</button>
			</div>
		</div>

		<div class="mb-3">
			<div class="text-xs opacity-70 mb-1">Field policy (remembered per workspace):</div>
			<div class="max-h-64 overflow-y-auto rounded border border-base-300">
				<table class="table table-xs">
					<thead class="sticky top-0 bg-base-200">
						<tr><th>Field</th><th class="w-16 text-center">Keep</th><th class="w-16 text-center">Mask</th><th class="w-16 text-center">Hide</th></tr>
					</thead>
					<tbody>
						@foreach (var path in Model.ShareFieldPaths)
						{
							var mode = Model.MaskingPolicy.ModeFor(path);
							<tr>
								<td class="font-mono">@path</td>
								<td class="text-center">
									<input type="radio" class="radio radio-xs" name="mode@path" value="keep" checked="@(mode == YobaLog.Core.Sharing.MaskMode.Keep)" data-share-radio data-path="@path" />
								</td>
								<td class="text-center">
									<input type="radio" class="radio radio-xs" name="mode@path" value="mask" checked="@(mode == YobaLog.Core.Sharing.MaskMode.Mask)" data-share-radio data-path="@path" />
								</td>
								<td class="text-center">
									<input type="radio" class="radio radio-xs" name="mode@path" value="hide" checked="@(mode == YobaLog.Core.Sharing.MaskMode.Hide)" data-share-radio data-path="@path" />
								</td>
							</tr>
						}
					</tbody>
				</table>
			</div>
		</div>

		<div class="flex gap-2">
			<button type="button" id="share-generate" class="btn btn-sm btn-primary">Generate</button>
			<form method="dialog" class="contents"><button class="btn btn-sm btn-ghost">Close</button></form>
		</div>

		<div id="share-result" class="hidden mt-3">
			<div class="join w-full">
				<input id="share-url" type="text" readonly class="input input-sm input-bordered join-item w-full font-mono text-xs" />
				<button type="button" class="btn btn-sm join-item" data-share-copy>Copy</button>
			</div>
			<p class="text-xs opacity-60 mt-1">Expires at <span id="share-expires"></span>.</p>
		</div>

		<div id="share-error" class="hidden mt-3 alert alert-error text-xs"></div>
	</div>
	<form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

@if (Model.KqlError is not null)
{
	<div class="alert alert-error mb-4">
		<pre class="whitespace-pre-wrap text-xs">@Model.KqlError</pre>
	</div>
}
else if (Model.SchemaMissing)
{
	<div class="alert">Workspace has no events yet.</div>
}
else if (Model.IsShapeChanged)
{
	if (Model.KqlRows.Count == 0)
	{
		<div class="alert">Query returned no rows.</div>
	}
	else
	{
		<div class="overflow-x-auto rounded-box border border-base-300 bg-base-200">
			<table class="table table-sm">
				<thead>
					<tr>
						@foreach (var col in Model.KqlResult!.Columns)
						{
							<th class="font-mono text-xs">@col.Name</th>
						}
					</tr>
				</thead>
				<tbody>
					@foreach (var row in Model.KqlRows)
					{
						<tr class="align-top">
							@foreach (var cell in row)
							{
								<td class="font-mono text-xs">@(cell?.ToString() ?? "")</td>
							}
						</tr>
					}
				</tbody>
			</table>
		</div>
	}
}
else if (Model.Events.Count == 0)
{
	<div class="alert">No events match the filter.</div>
}
else
{
	<div class="overflow-x-auto rounded-box border border-base-300 bg-base-200">
		<table class="table table-sm">
			<thead>
				<tr>
					<th class="w-44">Time (UTC)</th>
					<th class="w-24">Level</th>
					<th>Message</th>
					<th class="w-40">Trace</th>
				</tr>
			</thead>
			<tbody id="events-body">
				<partial name="_RowsFragment" model="Model" />
			</tbody>
		</table>
	</div>
}
