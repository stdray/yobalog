@using YobaLog.Web
@model EqNeChipsModel
<span class="hidden group-hover/field:inline-flex items-center gap-1">
	<button type="button" class="filter-chip text-success text-sm leading-none px-1"
		data-filter-field="@Model.Field" data-filter-op="eq" data-filter-value="@Model.KqlLiteral"
		title="only this value">✓</button>
	<button type="button" class="filter-chip text-error text-sm leading-none px-1"
		data-filter-field="@Model.Field" data-filter-op="ne" data-filter-value="@Model.KqlLiteral"
		title="exclude this value">✗</button>
</span>
