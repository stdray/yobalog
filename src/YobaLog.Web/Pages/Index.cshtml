@page
@model YobaLog.Web.Pages.IndexModel
@{
	ViewData["Title"] = "Workspaces";
}

<h1 class="text-2xl font-semibold mb-4">Workspaces</h1>

@if (Model.Workspaces.Length == 0)
{
	<p class="opacity-70">No workspaces configured. Add API keys in <code class="kbd kbd-sm">appsettings.json</code>.</p>
}
else
{
	<ul class="menu bg-base-200 rounded-box border border-base-300 w-full" data-testid="workspace-list">
		@foreach (var ws in Model.Workspaces)
		{
			<li>
				<a asp-page="/Workspace" asp-route-id="@ws.Value"
					data-testid="workspace-link"
					data-workspace-id="@ws.Value"
					class="flex items-center justify-between">
					<span class="font-mono @(ws.IsSystem ? "text-secondary" : "")">@ws.Value</span>
					<span class="text-sm opacity-60">View events →</span>
				</a>
			</li>
		}
	</ul>
}
