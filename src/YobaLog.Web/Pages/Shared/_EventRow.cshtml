@using YobaLog.Web
@model EventRowViewModel
@{
	var rowClasses = "align-top hover" + (Model.IsLive ? " event-live" : " cursor-pointer");
	var showChips = !Model.IsLive;
	var tsKql = EventRowViewModel.KqlDatetime(Model.Timestamp);
	var levelInt = ((int)Model.Level).ToString(System.Globalization.CultureInfo.InvariantCulture);
	var traceKql = EventRowViewModel.KqlString(Model.TraceId);
}
<tr class="@rowClasses"@(Model.IsLive || Model.Id is null ? "" : $" data-event-id=\"{Model.Id}\"")>
	<td class="font-mono text-xs opacity-70 whitespace-nowrap relative group">
		<time class="local-time" datetime="@EventRowViewModel.IsoUtc(Model.Timestamp)" title="UTC: @EventRowViewModel.IsoUtc(Model.Timestamp)">@Model.Timestamp.UtcDateTime.ToString("yyyy-MM-dd HH:mm:ss.fff")</time>
		@if (showChips)
		{
			<span class="absolute inset-y-0 right-1 hidden group-hover:inline-flex items-center gap-1 bg-base-300 rounded px-1 shadow">
				<button type="button" class="filter-chip text-success text-xs font-semibold leading-none px-1"
					data-filter-field="Timestamp" data-filter-op="ge" data-filter-value="@tsKql"
					title="search from this moment (inclusive)">from</button>
				<button type="button" class="filter-chip text-error text-xs font-semibold leading-none px-1"
					data-filter-field="Timestamp" data-filter-op="le" data-filter-value="@tsKql"
					title="search up to this moment (inclusive)">to</button>
			</span>
		}
	</td>
	<td class="relative group">
		<span class="badge badge-sm @EventRowViewModel.LevelBadge(Model.Level)">@Model.Level</span>
		@if (showChips)
		{
			<span class="absolute inset-y-0 right-0 hidden group-hover:inline-flex items-center gap-1 bg-base-300 rounded px-1 shadow">
				<button type="button" class="filter-chip text-success text-sm leading-none"
					data-filter-field="Level" data-filter-op="eq" data-filter-value="@levelInt"
					title="only this level">✓</button>
				<button type="button" class="filter-chip text-error text-sm leading-none"
					data-filter-field="Level" data-filter-op="ne" data-filter-value="@levelInt"
					title="exclude this level">✗</button>
			</span>
		}
	</td>
	<td class="break-words">
		<div class="flex items-start gap-2">
			<span class="flex-1">@Model.Message</span>
			@if (!Model.IsLive)
			{
				<button type="button" class="btn btn-ghost btn-xs opacity-40 hover:opacity-100"
					data-copy="@Model.Message"
					title="Copy message">⧉</button>
			}
		</div>
		@if (!string.IsNullOrEmpty(Model.Exception))
		{
			<pre class="mt-1 text-xs text-error whitespace-pre-wrap">@Model.Exception</pre>
		}
	</td>
	<td class="font-mono text-xs opacity-70 truncate relative group">
		@Model.TraceId
		@if (showChips && !string.IsNullOrEmpty(Model.TraceId))
		{
			<span class="absolute inset-y-0 right-0 hidden group-hover:inline-flex items-center gap-1 bg-base-300 rounded px-1 shadow">
				<button type="button" class="filter-chip text-success text-sm leading-none"
					data-filter-field="TraceId" data-filter-op="eq" data-filter-value="@traceKql"
					title="only this trace">✓</button>
				<button type="button" class="filter-chip text-error text-sm leading-none"
					data-filter-field="TraceId" data-filter-op="ne" data-filter-value="@traceKql"
					title="exclude this trace">✗</button>
			</span>
		}
	</td>
</tr>
@if (!Model.IsLive && Model.Id is not null)
{
	var idLit = Model.Id.Value.ToString(System.Globalization.CultureInfo.InvariantCulture);
	var levelLit = ((int)Model.Level).ToString(System.Globalization.CultureInfo.InvariantCulture);

	<tr class="event-details hidden bg-base-300/50">
		<td colspan="4" class="text-xs">
			<dl class="grid grid-cols-[auto_1fr] gap-x-4 gap-y-1 font-mono">
				<dt class="opacity-60">Id</dt>
				<dd class="flex items-center gap-2 group/field">
					<span>@Model.Id</span>
					@await Html.PartialAsync("_EqNeChips", new EqNeChipsModel("Id", idLit))
				</dd>

				<dt class="opacity-60">Timestamp</dt>
				<dd class="flex items-center gap-2 group/field">
					<time class="local-time" datetime="@EventRowViewModel.IsoUtc(Model.Timestamp)" title="UTC: @EventRowViewModel.IsoUtc(Model.Timestamp)">@EventRowViewModel.IsoUtc(Model.Timestamp)</time>
					<span class="hidden group-hover/field:inline-flex items-center gap-1">
						<button type="button" class="filter-chip text-success text-xs font-semibold leading-none px-1"
							data-filter-field="Timestamp" data-filter-op="ge" data-filter-value="@EventRowViewModel.KqlDatetime(Model.Timestamp)"
							title="search from this moment (inclusive)">from</button>
						<button type="button" class="filter-chip text-error text-xs font-semibold leading-none px-1"
							data-filter-field="Timestamp" data-filter-op="le" data-filter-value="@EventRowViewModel.KqlDatetime(Model.Timestamp)"
							title="search up to this moment (inclusive)">to</button>
					</span>
				</dd>

				<dt class="opacity-60">Level</dt>
				<dd class="flex items-center gap-2 group/field">
					<span>@Model.Level (@((int)Model.Level))</span>
					@await Html.PartialAsync("_EqNeChips", new EqNeChipsModel("Level", levelLit))
				</dd>

				@if (!string.IsNullOrEmpty(Model.MessageTemplate) && Model.MessageTemplate != Model.Message)
				{
					<dt class="opacity-60">Template</dt>
					<dd class="flex items-center gap-2 break-all group/field">
						<span>@Model.MessageTemplate</span>
						@await Html.PartialAsync("_EqNeChips", new EqNeChipsModel("MessageTemplate", EventRowViewModel.KqlString(Model.MessageTemplate)))
					</dd>
				}

				@if (!string.IsNullOrEmpty(Model.TraceId))
				{
					<dt class="opacity-60">TraceId</dt>
					<dd class="flex items-center gap-2 group/field">
						<span>@Model.TraceId</span>
						@await Html.PartialAsync("_EqNeChips", new EqNeChipsModel("TraceId", EventRowViewModel.KqlString(Model.TraceId)))
						<button type="button" class="btn btn-ghost btn-xs opacity-40 hover:opacity-100"
							data-copy="@Model.TraceId" title="Copy trace id">⧉</button>
					</dd>
				}

				@if (!string.IsNullOrEmpty(Model.SpanId))
				{
					<dt class="opacity-60">SpanId</dt>
					<dd class="flex items-center gap-2 group/field">
						<span>@Model.SpanId</span>
						@await Html.PartialAsync("_EqNeChips", new EqNeChipsModel("SpanId", EventRowViewModel.KqlString(Model.SpanId)))
					</dd>
				}

				@if (Model.EventId is not null)
				{
					var eventIdLit = Model.EventId.Value.ToString(System.Globalization.CultureInfo.InvariantCulture);
					<dt class="opacity-60">EventId</dt>
					<dd class="flex items-center gap-2 group/field">
						<span>@Model.EventId</span>
						@await Html.PartialAsync("_EqNeChips", new EqNeChipsModel("EventId", eventIdLit))
					</dd>
				}

				@foreach (var (key, value) in Model.Properties)
				{
					var (display, kqlLit) = EventRowViewModel.PropertyForDisplay(value);
					var field = "Properties." + key;
					<dt class="opacity-60">@key</dt>
					<dd class="flex items-center gap-2 break-all group/field">
						<span>@display</span>
						@if (kqlLit is not null)
						{
							@await Html.PartialAsync("_EqNeChips", new EqNeChipsModel(field, kqlLit))
						}
						<button type="button" class="btn btn-ghost btn-xs opacity-40 hover:opacity-100"
							data-copy="@display" title="Copy value">⧉</button>
					</dd>
				}
			</dl>
		</td>
	</tr>
}
