@page "/trace/{id}"
@model YobaLog.Web.Pages.TraceModel
@{
	ViewData["Title"] = $"Trace {Model.TraceId}";
}

<nav class="mb-4 flex flex-wrap items-center gap-2 text-sm" aria-label="breadcrumb">
	<a asp-page="/Workspace" asp-route-id="@Model.Workspace.Value"
		class="hover:opacity-100 opacity-60" data-testid="trace-back-workspace">@Model.Workspace.Value</a>
	<span class="opacity-40">/</span>
	<a asp-page="/Traces" asp-route-id="@Model.Workspace.Value"
		class="hover:opacity-100 opacity-60" data-testid="trace-back-traces">traces</a>
	<span class="opacity-40">/</span>
	<span class="font-mono font-semibold text-base" data-testid="trace-id">@Model.TraceId</span>
	@if (Model.Rows.Length > 0)
	{
		<span class="badge badge-ghost font-mono ml-2 text-xs" data-testid="trace-span-count">@Model.Rows.Length spans</span>
		<span class="badge badge-ghost font-mono text-xs" data-testid="trace-duration">@($"{Model.TraceDuration.TotalMilliseconds:F1}ms")</span>
	}
</nav>

@if (Model.NotFoundMessage is not null)
{
	<div class="alert alert-warning" data-testid="trace-not-found">@Model.NotFoundMessage</div>
}
else
{
	<partial name="_TraceWaterfall" model="Model" />
}
